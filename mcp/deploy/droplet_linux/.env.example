# KDSE MCP Server - Environment Configuration
# Copy this file to .env and configure for your environment

# Transport mode: stdio (local) or http (remote)
MCP_TRANSPORT=http

# HTTP server port (used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=8080

# Repository root inside container (do not change)
KDSE_REPO_ROOT=/app

# Docker image tag
IMAGE_TAG=latest

# Container name prefix
CONTAINER_PREFIX=kdse-mcp

# Network configuration
NETWORK_NAME=kdse-network

# Log configuration
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3

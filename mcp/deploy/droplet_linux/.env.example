# KDSE MCP Server - Production Environment Variables
# Copy this file to .env and customize for your deployment

# =============================================================================
# BUILD CONFIGURATION
# =============================================================================

# Path to mcp-server source (relative to this directory)
# Default: ../../../mcp-server (from deploy/droplet_linux/)
KDSE_BUILD_CONTEXT=../../../mcp-server

# Dockerfile name (relative to build context)
KDSE_DOCKERFILE=Dockerfile

# =============================================================================
# IMAGE CONFIGURATION
# =============================================================================

# Docker image name (default: kdse-mcp-server)
KDSE_IMAGE=kdse-mcp-server

# Docker image tag (default: latest)
# Note: With local build, tag is assigned after build completes
KDSE_TAG=latest

# =============================================================================
# CONTAINER CONFIGURATION
# =============================================================================

# Fixed container name (default: kdse-mcp-server)
KDSE_CONTAINER_NAME=kdse-mcp-server

# Network name for container communication
KDSE_NETWORK=kdse-mcp-network

# =============================================================================
# DATA PATHS
# =============================================================================

# Path to KDSE repository data on the host (mounted read-only in container)
KDSE_DATA_PATH=/data/kdse

# Root path of KDSE repository inside the container
KDSE_REPO_ROOT=/data/kdse

# =============================================================================
# MCP SERVER CONFIGURATION
# =============================================================================

# Use stdio transport (required for MCP over stdin/stdout)
# Set to 'true' for MCP clients like OpenHands
MCP_STDIO=true

# =============================================================================
# OPTIONAL: HTTP TRANSPORT (for future use)
# =============================================================================

# Uncomment and set port if enabling HTTP transport mode
# MCP_HTTP_PORT=8080

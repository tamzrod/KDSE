#-------------------------------------------------------------------------------
# Command: doctor
#-------------------------------------------------------------------------------

cmd_doctor() {
    output_header "Runtime Diagnostics"
    
    local install_path=$(get_install_path)
    local issues=0
    local warnings=0
    
    # Check if installed
    if ! manifest_exists; then
        output_error "Runtime is not installed"
        echo ""
        echo "Recommendation: Run 'kdse install' to install the runtime."
        echo ""
        output_footer
        return $EXIT_NOT_INSTALLED
    fi
    
    echo -e "${BOLD}Checking Installation...${NC}"
    
    # Check directories
    local dirs=("reports" "history" "runtime" "cache" "configuration")
    for dir in "${dirs[@]}"; do
        if [[ -d "${install_path}/${dir}" ]]; then
            output_success "$dir/"
        else
            output_error "Missing directory: $dir/"
            ((issues++))
        fi
    done
    
    # Check standards
    if [[ -d "${install_path}/standards/normative" ]]; then
        local norm_count=$(find "${install_path}/standards/normative" -name "*.md" 2>/dev/null | wc -l)
        if [[ $norm_count -gt 0 ]]; then
            output_success "Normative documents: $norm_count"
        else
            output_error "No normative documents found"
            ((issues++))
        fi
    else
        output_error "Standards directory missing"
        ((issues++))
    fi
    
    # Check manifest format
    local format=$(detect_manifest_format)
    if [[ "$format" == "yaml" ]]; then
        output_warning "Legacy manifest format detected (YAML)"
        echo "  Recommendation: Run 'kdse update' to migrate to JSON"
        ((warnings++))
    elif [[ "$format" == "json" ]]; then
        output_success "Manifest format: JSON (current)"
    fi
    
    # Check git repository
    if [[ -d "${install_path}/.git" ]]; then
        output_success "Git repository: present"
    else
        output_warning "Git repository: not found (sync may not work)"
        ((warnings++))
    fi
    
    # Check disk space
    local available=$(df -h "${install_path}" 2>/dev/null | awk 'NR==2 {print $4}' || echo "unknown")
    output_info "Disk space available: $available"
    
    echo ""
    echo -e "${BOLD}Summary:${NC}"
    echo "  Issues:   $issues"
    echo "  Warnings: $warnings"
    
    if [[ $issues -gt 0 ]]; then
        echo ""
        output_error "Runtime has issues that need attention"
        echo ""
        echo "Recommendations:"
        echo "  1. Run 'kdse update' to repair installation"
        echo "  2. If issues persist, run 'kdse install --force'"
    elif [[ $warnings -gt 0 ]]; then
        echo ""
        output_warning "Runtime has warnings but is functional"
    else
        echo ""
        output_success "Runtime is healthy"
    fi
    
    output_footer
    
    [[ $issues -gt 0 ]] && return $EXIT_ERROR || return $EXIT_OK
}


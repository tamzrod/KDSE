#!/usr/bin/env bash
#===============================================================================
# KDSE Runtime Engineering Command Interface
#===============================================================================
# Purpose: Provide deterministic engineering operations for KDSE Runtime
# Design:  Deterministic, idempotent, no AI logic, no engineering decisions
#===============================================================================

set -euo pipefail

#-------------------------------------------------------------------------------
# Configuration
#-------------------------------------------------------------------------------

# KDSE home directory
KDSE_HOME="${KDSE_HOME:-$HOME}"

# Installation directory
KDSE_DIR=".kdse"

# Commands directory
COMMANDS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

#-------------------------------------------------------------------------------
# ANSI Colors
#-------------------------------------------------------------------------------

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

#-------------------------------------------------------------------------------
# Output Functions
#-------------------------------------------------------------------------------

output_info() {
    echo -e "${BLUE}[INFO]${NC} $*"
}

output_success() {
    echo -e "${GREEN}[OK]${NC} $*"
}

output_warning() {
    echo -e "${YELLOW}[WARN]${NC} $*"
}

output_error() {
    echo -e "${RED}[ERROR]${NC} $*" >&2
}

output_header() {
    echo ""
    echo -e "${BOLD}${CYAN}============================================================${NC}"
    echo -e "${BOLD}${CYAN} KDSE Runtime${NC} - $1"
    echo -e "${BOLD}${CYAN}============================================================${NC}"
    echo ""
}

output_footer() {
    echo -e "${BOLD}${CYAN}============================================================${NC}"
    echo ""
}

#-------------------------------------------------------------------------------
# Path Utilities
#-------------------------------------------------------------------------------

get_install_path() {
    echo "${KDSE_HOME}/${KDSE_DIR}"
}

get_manifest_path() {
    echo "$(get_install_path)/manifest.json"
}

get_legacy_manifest_path() {
    echo "$(get_install_path)/manifest.yaml"
}

get_reports_path() {
    echo "$(get_install_path)/reports"
}

get_history_path() {
    echo "$(get_install_path)/history"
}

#-------------------------------------------------------------------------------
# Manifest Detection (simplified for kdse command)
#-------------------------------------------------------------------------------

detect_manifest_format() {
    local install_path=$(get_install_path)
    
    if [[ ! -d "$install_path" ]]; then
        echo "none"
        return
    fi
    
    if [[ -f "${install_path}/manifest.json" ]] && grep -q '"kdse"' "${install_path}/manifest.json" 2>/dev/null; then
        echo "json"
        return
    fi
    
    if [[ -f "${install_path}/manifest.yaml" ]] && grep -q 'kdse' "${install_path}/manifest.yaml" 2>/dev/null; then
        echo "yaml"
        return
    fi
    
    echo "none"
}

manifest_exists() {
    [[ "$(detect_manifest_format)" != "none" ]]
}

#-------------------------------------------------------------------------------
# Manifest Reading
#-------------------------------------------------------------------------------

manifest_get() {
    local key="$1"
    local manifest=$(get_manifest_path)
    
    if [[ -f "$manifest" ]]; then
        case "$key" in
            version)
                grep '"version"' "$manifest" 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/'
                ;;
            installed)
                grep '"installed"' "$manifest" 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/'
                ;;
            repo)
                grep '"repo"' "$manifest" 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/'
                ;;
            branch)
                grep '"branch"' "$manifest" 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/'
                ;;
            last_sync)
                grep '"last_sync"' "$manifest" 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/'
                ;;
        esac
        return
    fi
    
    # Fallback to YAML
    local yaml_manifest=$(get_legacy_manifest_path)
    if [[ -f "$yaml_manifest" ]]; then
        case "$key" in
            version)
                awk '/^[[:space:]]*version:/ {gsub(/["'\'']/, "", $2); print $2; exit}' "$yaml_manifest"
                ;;
            installed)
                awk '/^[[:space:]]*installed:/ {gsub(/["'\'']/, "", $2); for(i=2;i<=NF;i++) printf "%s ", $i; print ""; exit}' "$yaml_manifest" | xargs
                ;;
            repo)
                awk '/^[[:space:]]*repo:/ {gsub(/["'\'']/, "", $2); for(i=2;i<=NF;i++) printf "%s ", $i; print ""; exit}' "$yaml_manifest" | xargs
                ;;
            branch)
                awk '/^[[:space:]]*branch:/ {gsub(/["'\'']/, "", $2); print $2; exit}' "$yaml_manifest"
                ;;
        esac
    fi
}

#-------------------------------------------------------------------------------
# Platform Detection
#-------------------------------------------------------------------------------

detect_platform() {
    case "$(uname -s)" in
        Linux*)  echo "linux" ;;
        Darwin*) echo "macos" ;;
        *)       echo "unknown" ;;
    esac
}

#-------------------------------------------------------------------------------
# Timestamp
#-------------------------------------------------------------------------------

get_timestamp() {
    date -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date -u +"%Y-%m-%d %H:%M:%S UTC"
}

#-------------------------------------------------------------------------------
# Exit Codes
#-------------------------------------------------------------------------------

EXIT_OK=0
EXIT_ERROR=1
EXIT_NOT_INSTALLED=2
EXIT_INVALID_ARGS=3

#-------------------------------------------------------------------------------
# Usage
#-------------------------------------------------------------------------------

usage() {
    cat <<EOF
${BOLD}KDSE Runtime${NC} - Engineering Command Interface

${BOLD}USAGE:${NC}
    kdse <command> [options]

${BOLD}COMMANDS:${NC}
    status          Show runtime health and status
    version         Show runtime version
    commands        List all available commands
    update          Update runtime to latest version
    verify          Verify runtime installation
    doctor          Diagnose runtime problems
    run             Start a new KDSE session
    resume          Resume previous session
    audit           Execute repository assessment
    history         Show session history
    report          List available reports
    install         Install runtime (if not installed)
    uninstall       Remove runtime

${BOLD}OPTIONS:${NC}
    -h, --help      Show this help message
    -v, --verbose   Verbose output
    -q, --quiet     Quiet output (only errors)

${BOLD}EXAMPLES:${NC}
    kdse status         # Show runtime status
    kdse commands       # List all commands
    kdse update         # Update runtime
    kdse verify         # Verify installation
    kdse run            # Start new session

${BOLD}AGENT INTEGRATION:${NC}
    The KDSE Runtime is self-describing. AI agents should:
    1. Run 'kdse commands' to discover available commands
    2. Map natural language to commands using registry
    3. Invoke the command directly without reasoning

EOF
    exit $EXIT_OK
}

#-------------------------------------------------------------------------------
# Command: status
#-------------------------------------------------------------------------------

cmd_status() {
    output_header "Runtime Status"
    
    local install_path=$(get_install_path)
    local format=$(detect_manifest_format)
    
    # Check if installed
    if ! manifest_exists; then
        output_error "Runtime is not installed"
        echo ""
        echo "Run 'kdse install' to install the runtime."
        output_footer
        return $EXIT_NOT_INSTALLED
    fi
    
    # Get manifest values
    local version=$(manifest_get "version" || echo "unknown")
    local installed=$(manifest_get "installed" || echo "unknown")
    local repo=$(manifest_get "repo" || echo "unknown")
    local branch=$(manifest_get "branch" || echo "unknown")
    local last_sync=$(manifest_get "last_sync" || echo "never")
    
    # Display status
    echo -e "${BOLD}Installation:${NC}"
    echo "  Path:        $install_path"
    echo "  Format:      $format"
    echo "  Version:     $version"
    echo "  Installed:   $installed"
    echo "  Last Sync:   $last_sync"
    echo "  Repository:  $repo"
    echo "  Branch:      $branch"
    echo "  Platform:    $(detect_platform)"
    echo ""
    
    # Check required directories
    echo -e "${BOLD}Directories:${NC}"
    local dirs=("reports" "history" "runtime" "cache" "configuration" "standards/normative" "standards/informative")
    local all_present=1
    for dir in "${dirs[@]}"; do
        if [[ -d "${install_path}/${dir}" ]]; then
            echo "  ✓ $dir/"
        else
            echo "  ✗ $dir/ (missing)"
            all_present=0
        fi
    done
    echo ""
    
    # Check for session state
    local session_state="${install_path}/runtime/state.txt"
    if [[ -f "$session_state" ]]; then
        echo -e "${BOLD}Session State:${NC}"
        echo "  Active session found"
        echo ""
    fi
    
    # Required action
    echo -e "${BOLD}Required Action:${NC}"
    if [[ "$format" == "yaml" ]]; then
        echo "  Migration recommended (YAML -> JSON)"
    elif [[ "$all_present" == "0" ]]; then
        echo "  Run 'kdse verify' to diagnose"
    else
        echo "  None - runtime healthy"
    fi
    
    output_footer
    return $EXIT_OK
}

#-------------------------------------------------------------------------------
# Command: version
#-------------------------------------------------------------------------------

cmd_version() {
    if ! manifest_exists; then
        output_error "Runtime is not installed"
        return $EXIT_NOT_INSTALLED
    fi
    
    local version=$(manifest_get "version" || echo "unknown")
    local installed=$(manifest_get "installed" || echo "unknown")
    
    echo "KDSE Runtime"
    echo "Version:    $version"
    echo "Installed:  $installed"
    echo "Interface:  1.0"
    
    return $EXIT_OK
}

#-------------------------------------------------------------------------------
# Command: update
#-------------------------------------------------------------------------------

cmd_update() {
    output_header "Runtime Update"
    
    if ! manifest_exists; then
        output_error "Runtime is not installed"
        echo ""
        echo "Run 'kdse install' to install the runtime."
        output_footer
        return $EXIT_NOT_INSTALLED
    fi
    
    output_info "Running synchronization..."
    echo ""
    
    # Run sync script
    if [[ -f "${COMMANDS_DIR}/sync.sh" ]]; then
        source "${COMMANDS_DIR}/common.sh"
        "${COMMANDS_DIR}/sync.sh"
    else
        output_error "Sync script not found"
        output_footer
        return $EXIT_ERROR
    fi
    
    local exit_code=$?
    
    if [[ $exit_code -eq 0 ]]; then
        output_success "Runtime updated successfully"
    else
        output_error "Runtime update failed"
    fi
    
    output_footer
    return $exit_code
}


    echo "  MAINTENANCE COMMANDS:"
    echo "    update     - Update runtime to latest version"
    echo "    verify     - Verify installation integrity"
    echo "    doctor     - Diagnose runtime problems"
    echo ""
    echo "  SESSION COMMANDS:"
    echo "    run        - Start a new KDSE session"

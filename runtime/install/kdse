    echo ""
    echo -e "${BOLD}Available Commands:${NC}"
    echo ""
    echo "  INFORMATION COMMANDS:"
    echo "    status     - Show runtime health and status"
    echo "    version    - Display runtime version"
    echo "    commands   - List all available commands"

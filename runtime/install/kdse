#-------------------------------------------------------------------------------
# Main
#-------------------------------------------------------------------------------

main() {
    # Parse global options
    VERBOSE=0
    QUIET=0
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                ;;
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            -q|--quiet)
                QUIET=1
                shift
                ;;
            -*)
                output_error "Unknown option: $1"
                echo "Run 'kdse --help' for usage."
                exit $EXIT_INVALID_ARGS
                ;;
            *)
                break
                ;;
        esac
    done
    
    # Get command
    local command="${1:-}"
    shift || true
    
    # Route command
    case "$command" in
        status)
            cmd_status "$@"
            ;;
        version)
            cmd_version "$@"
            ;;
        commands)
            cmd_commands "$@"
            ;;
        update)
            cmd_update "$@"
            ;;
        verify)
            cmd_verify "$@"
            ;;
        doctor)
            cmd_doctor "$@"
            ;;
        install)
            cmd_install "$@"
            ;;
        uninstall)
            cmd_uninstall "$@"
            ;;
        history)
            cmd_history "$@"
            ;;
        report)
            cmd_report "$@"
            ;;
        run)
            cmd_run "$@"
            ;;
        resume)
            cmd_resume "$@"
            ;;
        audit)
            cmd_audit "$@"
            ;;
        "")
            output_header "KDSE Runtime"
            echo "KDSE Runtime - Engineering Command Interface"
            echo ""
            echo "Version: 1.0"
            echo ""
            echo "Run 'kdse --help' for usage."
            echo "Run 'kdse status' to check runtime health."
            output_footer
            ;;
        *)
            output_error "Unknown command: $command"
            echo "Run 'kdse --help' for usage."
            exit $EXIT_INVALID_ARGS
            ;;
    esac
}

# Run
main "$@"

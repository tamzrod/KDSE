#-------------------------------------------------------------------------------
# Command: history
#-------------------------------------------------------------------------------

cmd_history() {
    output_header "Session History"
    
    local history_path=$(get_history_path)
    
    if [[ ! -d "$history_path" ]]; then
        output_warning "History directory not found"
        output_footer
        return $EXIT_OK
    fi
    
    local sessions=$(find "$history_path" -name "*.json" -o -name "*.md" 2>/dev/null | sort -r)
    
    if [[ -z "$sessions" ]]; then
        output_info "No session history found"
        echo ""
        echo "Run 'kdse run' to start a new session."
    else
        echo -e "${BOLD}Recent Sessions:${NC}"
        local count=0
        while IFS= read -r session && [[ $count -lt 10 ]]; do
            local basename=$(basename "$session")
            local modified=$(stat -c %y "$session" 2>/dev/null | cut -d' ' -f1 || stat -f %Sm "$session" 2>/dev/null | cut -d' ' -f1 || echo "unknown")
            echo "  $modified  $basename"
            ((count++))
        done <<< "$sessions"
        echo ""
        echo "Total sessions: $(echo "$sessions" | wc -l | tr -d ' ')"
    fi
    
    output_footer
    return $EXIT_OK
}

#-------------------------------------------------------------------------------
# Command: report
#-------------------------------------------------------------------------------

cmd_report() {
    output_header "Available Reports"
    
    local reports_path=$(get_reports_path)
    
    if [[ ! -d "$reports_path" ]]; then
        output_warning "Reports directory not found"
        output_footer
        return $EXIT_OK
    fi
    
    local reports=$(find "$reports_path" -type f \( -name "*.json" -o -name "*.md" -o -name "*.html" \) 2>/dev/null | sort -r)
    
    if [[ -z "$reports" ]]; then
        output_info "No reports found"
        echo ""
        echo "Run 'kdse run' to generate reports."
    else
        echo -e "${BOLD}Reports:${NC}"
        local count=0
        while IFS= read -r report && [[ $count -lt 20 ]]; do
            local basename=$(basename "$report")
            local size=$(stat -c %s "$report" 2>/dev/null || stat -f %z "$report" 2>/dev/null || echo "0")
            local size_str=""
            if [[ $size -gt 1024 ]]; then
                size_str=" ($(($size / 1024))KB)"
            fi
            echo "  $basename$size_str"
            ((count++))
        done <<< "$reports"
        echo ""
        echo "Total reports: $(echo "$reports" | wc -l | tr -d ' ')"
    fi
    
    output_footer
    return $EXIT_OK
}

#-------------------------------------------------------------------------------
# Command: run
#-------------------------------------------------------------------------------

cmd_run() {
    output_header "Start KDSE Session"
    
    if ! manifest_exists; then
        output_error "Runtime is not installed"
        echo ""
        echo "Run 'kdse install' first."
        output_footer
        return $EXIT_NOT_INSTALLED
    fi
    
    output_info "Session initialization..."
    echo ""
    
    # Check if session already active
    local state_file="$(get_install_path)/runtime/state.txt"
    if [[ -f "$state_file" ]]; then
        output_warning "An active session exists"
        echo ""
        echo "Use 'kdse resume' to continue the session, or close it first."
        output_footer
        return $EXIT_OK
    fi
    
    # Create session state
    local session_id="KDSE-$(date +%Y%m%d-%H%M%S)"
    mkdir -p "$(get_install_path)/runtime"
    echo "$session_id" > "$state_file"
    echo "active" >> "$state_file"
    echo "$(get_timestamp)" >> "$state_file"
    
    output_success "Session started: $session_id"
    echo ""
    echo -e "${BOLD}Session ID:${NC} $session_id"
    echo -e "${BOLD}State:${NC}     active"
    echo ""
    echo "The Runtime will now execute the session workflow."
    echo "Use 'kdse resume' to continue if interrupted."
    
    output_footer
    return $EXIT_OK
}

#-------------------------------------------------------------------------------
# Command: resume
#-------------------------------------------------------------------------------

cmd_resume() {
    output_header "Resume KDSE Session"
    
    local state_file="$(get_install_path)/runtime/state.txt"
    
    if [[ ! -f "$state_file" ]]; then
        output_warning "No active session found"
        echo ""
        echo "Use 'kdse run' to start a new session."
        output_footer
        return $EXIT_OK
    fi
    
    local session_id=$(head -1 "$state_file")
    local state=$(sed -n '2p' "$state_file")
    local started=$(sed -n '3p' "$state_file")
    
    output_success "Session found: $session_id"
    echo ""
    echo -e "${BOLD}Session ID:${NC} $session_id"
    echo -e "${BOLD}State:${NC}     $state"
    echo -e "${BOLD}Started:${NC}   $started"
    echo ""
    echo "The Runtime will continue the session workflow."
    
    output_footer
    return $EXIT_OK
}

#-------------------------------------------------------------------------------
# Command: audit
#-------------------------------------------------------------------------------

cmd_audit() {
    output_header "Repository Assessment"
    
    if ! manifest_exists; then
        output_error "Runtime is not installed"
        output_footer
        return $EXIT_NOT_INSTALLED
    fi
    
    output_info "Executing repository assessment..."
    echo ""
    output_info "This would execute the Compliance Audit against the repository."
    echo ""
    output_info "Assessment dimensions:"
    echo "  - Knowledge"
    echo "  - Process"
    echo "  - Artifact"
    echo "  - Verification"
    echo "  - Traceability"
    echo ""
    output_info "Use 'kdse run' for a complete session including assessment."
    
    output_footer
    return $EXIT_OK
}

#-------------------------------------------------------------------------------
# Command: commands
#-------------------------------------------------------------------------------

cmd_commands() {
    local format="yaml"
    local output_mode="human"
    
    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -j|--json)
                format="json"
                shift
                ;;
            -y|--yaml)
                format="yaml"
                shift
                ;;
            -m|--machine)
                output_mode="machine"
                shift
                ;;
            *)
                shift
                ;;
        esac
    done
    
    local registry_path=$(get_install_path)/runtime/commands.yaml
    
    # Try to find registry in runtime directory first
    if [[ -f "$registry_path" ]]; then
        if [[ "$format" == "json" ]]; then
            # Convert YAML to JSON (basic)
            grep -v '^#' "$registry_path" | grep -v '^$' | head -50
        else
            output_header "KDSE Runtime Command Registry"
            echo ""
            echo "Registry: $registry_path"
            echo "Interface Version: 1.0"
            echo ""
            echo -e "${BOLD}Available Commands:${NC}"
            echo ""
            echo "  INFORMATION COMMANDS:"
            echo "    status     - Show runtime health and status"
            echo "    version    - Display runtime version"
            echo "    commands   - List all available commands"
            echo "    history    - Show session history"
            echo "    report     - List available reports"
            echo ""
            echo "  MAINTENANCE COMMANDS:"
            echo "    update     - Update runtime to latest version"
            echo "    verify     - Verify installation integrity"
            echo "    doctor     - Diagnose runtime problems"
            echo ""
            echo "  SESSION COMMANDS:"
            echo "    run        - Start a new KDSE session"
            echo "    resume     - Resume previous session"
            echo "    audit      - Execute repository assessment"
            echo ""
            echo "  ADMINISTRATION COMMANDS:"
            echo "    install    - Install runtime"
            echo "    uninstall  - Remove runtime"
            echo ""
            echo -e "${BOLD}Usage:${NC}"
            echo "  kdse <command> [options]"
            echo ""
            echo "Options:"
            echo "  -j, --json    Output in JSON format"
            echo "  -y, --yaml    Output in YAML format (default)"
            echo "  -m, --machine Machine-readable output"
            echo ""

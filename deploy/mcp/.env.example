# KDSE MCP Server - Environment Configuration
# Target: DigitalOcean with Nginx Proxy Manager
# Network: nginx-proxy-manager_default (external)

# Transport mode: stdio (local) or http (remote)
MCP_TRANSPORT=http

# HTTP server port (used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=18181

# Repository root inside container
KDSE_REPO_ROOT=/repo

# Docker image tag
IMAGE_TAG=production

# Log configuration
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3
